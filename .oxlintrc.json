{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "plugins": ["react", "typescript", "unicorn", "oxc"],
  "rules": {
    "react/react-in-jsx-scope": "off",
    "no-ternary": "off",
    "sort-imports": "off",
    "sort-keys": "off",
    "id-length": "off",
    "unicorn/prefer-global-this": "off"
  },
  "ignorePatterns": ["**/*.gen.*", "**/*.astro", ".omc", "dist", ".astro"]
}
